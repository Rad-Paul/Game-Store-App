
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  username String
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime?
  
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id Int @id @default(autoincrement())
  tokenHash String @unique
  userId Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// store a single active refresh token (simple approach)
// Better long-term: use a separate RefreshToken model for multi-device support
// more research needed

model Game {
  id Int @id @default(autoincrement())
  Title String @unique 
  Developer String
  Description String?
  releaseDate DateTime @db.Date
  registeredAt DateTime @default(now())

  gameGenres GameGenre[]
  keys GameKey[]
}

model GameKey {
  id Int @id @default(autoincrement())
  key String
  price Decimal
  gameId Int

  game Game @relation(fields: [gameId], references: [id])
}

model GameGenre {
  id Int @id @default(autoincrement())
  gameId Int
  genreId Int

  game Game @relation(fields: [gameId], references: [id])
  genre Genre @relation(fields: [genreId], references: [id])
}

model Genre {
  id Int @id @default(autoincrement())
  title String @unique

  gameGenres GameGenre[]
}